---
import Layout from '@layouts/Layout.astro';
import Container from '@components/shared/Container.astro';
import Paragraph from '@components/shared/Paragraph.astro';
import Title from '@components/shared/Title.astro';
---

<Layout title="ElaScout - Gestión de Deportistas para Scouts de Fútbol">
    <main class="flex flex-col gap-y-20 md:gap-y-32 overflow-hidden">

        <!-- Hero -->
        <section class="relative pt-32 lg:pt-36 pb-10">
            <span class="w-4/12 lg:w-2/12 aspect-square bg-gradient-to-tr from-emerald-500 to-green-400 absolute -top-5 lg:left-0 rounded-full skew-y-12 blur-2xl opacity-40 skew-x-12 rotate-90"></span>
            <span class="absolute -right-10 top-20 w-32 h-32 rotate-90 skew-x-12 rounded-3xl bg-emerald-400 blur-xl opacity-60 hidden lg:block"></span>
            <span class="absolute right-4 bottom-12 w-24 h-24 rounded-3xl bg-emerald-600 blur-xl opacity-80"></span>

            <Container className={"flex flex-col lg:flex-row gap-10 lg:gap-12"}>
                <!-- Text -->
                <div class="relative flex flex-col items-center text-center lg:text-left lg:py-7 xl:py-8 lg:items-start lg:max-w-none max-w-3xl mx-auto lg:mx-0 lg:flex-1 lg:w-1/2">
                    <span class="px-4 py-1.5 rounded-full border border-box-border bg-box-bg text-heading-3 text-sm font-medium mb-6 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-emerald-500">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 0v18M3 12h18M5.636 5.636l12.728 12.728M18.364 5.636 5.636 18.364"/>
                        </svg>
                        ElaScout
                    </span>
                    <h1 class="text-3xl/tight sm:text-4xl/tight md:text-5xl/tight xl:text-6xl/tight font-bold text-heading-1">
                        Gestiona y evalúa <span class="text-transparent bg-clip-text bg-gradient-to-br from-emerald-400 from-20% via-green-500 via-30% to-teal-600">deportistas</span> como un profesional.
                    </h1>
                    <Paragraph className="mt-8">
                        La plataforma diseñada para scouts de fútbol. Registra, analiza y evalúa técnica y tácticamente a cada jugador desde un solo lugar.
                    </Paragraph>
                    <div class="mt-10 flex flex-wrap justify-center lg:justify-start gap-4">
                        <a href="https://elascout.garaje88.dev" target="_blank"
                           class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-emerald-500 via-green-500 to-teal-600 text-white font-semibold shadow-lg hover:opacity-90 transition-opacity">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z"/>
                            </svg>
                            Ir a la app
                        </a>
                        <a href="#features"
                           class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-box-border bg-box-bg text-heading-2 font-semibold hover:border-emerald-500 transition-colors shadow-sm">
                            Ver funcionalidades
                        </a>
                        <a href="#screenshots"
                           class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-box-border bg-box-bg text-heading-2 font-semibold hover:border-emerald-500 transition-colors shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/>
                            </svg>
                            Ver capturas
                        </a>
                    </div>

                    <!-- Stats -->
                    <div class="mt-12 flex flex-wrap justify-center lg:justify-start gap-8">
                        {[
                            { value: "360°", label: "Evaluación del jugador" },
                            { value: "IA", label: "Reportes inteligentes" },
                            { value: "100%", label: "Orientado al scout" }
                        ].map(stat => (
                            <div class="text-center lg:text-left">
                                <p class="text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-br from-emerald-400 via-green-500 to-teal-600">{stat.value}</p>
                                <p class="text-xs text-heading-3 mt-0.5">{stat.label}</p>
                            </div>
                        ))}
                    </div>
                </div>

                <!-- Hero screenshot -->
                <div class="flex flex-1 lg:w-1/2 lg:h-auto relative lg:max-w-none lg:mx-0 mx-auto max-w-3xl">
                    <div class="absolute rotate-45 -left-5 md:-left-10 lg:-left-20 xl:-left-24 p-1 top-1/2 w-16 h-16 bg-gradient-to-br from-emerald-500 to-teal-400 blur-3xl opacity-50"></div>
                    <div class="absolute p-1 -top-4 md:-top-10 right-0 w-20 h-20 bg-gradient-to-br from-green-600 to-emerald-500 rounded-full blur-3xl opacity-60"></div>
                    <span class="absolute w-full aspect-[16/5] -skew-x-12 rounded-full bg-gradient-to-tr from-emerald-500 to-green-400 opacity-40 blur-2xl left-0 bottom-0"></span>
                    <div class="relative w-full rounded-3xl overflow-hidden border border-box-border shadow-[0px_8px_40px_rgb(var(--box-sd))]">
                        <img
                            src="/images/elascout/login.png"
                            alt="ElaScout - Login"
                            width="1280"
                            height="800"
                            class="w-full h-full object-cover"
                        />
                    </div>
                </div>
            </Container>
        </section>

        <!-- About / Descripción -->
        <section class="relative">
            <span class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 blur-3xl opacity-10 w-64 h-48 rounded-full bg-emerald-500"></span>
            <Container>
                <div class="text-center mb-12">
                    <span class="px-4 py-1.5 rounded-full border border-box-border bg-box-bg text-heading-3 text-sm font-medium">
                        ¿Qué es ElaScout?
                    </span>
                    <Title className="mt-4">
                        El sistema de gestión para <span class="text-transparent bg-clip-text bg-gradient-to-br from-emerald-400 from-20% via-green-500 via-30% to-teal-600">scouts de fútbol</span>
                    </Title>
                    <Paragraph className="mt-4 max-w-2xl mx-auto">
                        ElaScout es una plataforma integral diseñada específicamente para que los scouts de fútbol puedan administrar sus deportistas, realizar evaluaciones técnicas y tácticas, y generar reportes detallados con inteligencia artificial.
                    </Paragraph>
                </div>

                <div class="grid sm:grid-cols-3 gap-6">
                    {[
                        {
                            title: "Para el Scout",
                            description: "Centraliza la información de todos los jugadores que sigues. Sin papeles, sin hojas de cálculo. Todo digital y accesible desde cualquier lugar.",
                            color: "from-emerald-500 to-green-600",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>`
                        },
                        {
                            title: "Evaluación Técnica y Táctica",
                            description: "Califica habilidades técnicas, tácticas y físicas de cada jugador mediante formularios estructurados con visualización en gráficos de radar.",
                            color: "from-green-500 to-teal-600",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>`
                        },
                        {
                            title: "Reportes con IA",
                            description: "Genera reportes completos y detallados de tus deportistas en segundos, incluyendo gráficos, historial y análisis generado por inteligencia artificial.",
                            color: "from-teal-500 to-emerald-400",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>`
                        }
                    ].map(item => (
                        <div class="p-8 rounded-3xl bg-box-bg border border-box-border shadow-[0px_4px_24px_rgb(var(--box-sd))] flex flex-col gap-4 hover:border-emerald-500/40 transition-colors">
                            <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${item.color} flex items-center justify-center shrink-0 shadow-lg`}>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" class="w-7 h-7" set:html={item.icon}></svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-heading-1 text-lg mb-2">{item.title}</h3>
                                <p class="text-heading-3 text-sm leading-relaxed">{item.description}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </Container>
        </section>

        <!-- Features -->
        <section id="features" class="relative">
            <span class="absolute top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 blur-2xl opacity-10 w-48 h-36 rounded-full rotate-12 skew-x-6 bg-emerald-500"></span>
            <Container>
                <div class="text-center mb-12">
                    <span class="px-4 py-1.5 rounded-full border border-box-border bg-box-bg text-heading-3 text-sm font-medium">
                        Funcionalidades
                    </span>
                    <Title className="mt-4">
                        Todo lo que un scout necesita para <span class="text-transparent bg-clip-text bg-gradient-to-br from-emerald-400 from-20% via-green-500 via-30% to-teal-600">trabajar mejor</span>
                    </Title>
                </div>

                <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {[
                        {
                            title: "Dashboard en tiempo real",
                            description: "Visualiza el estado de tu organización: total de deportistas, evaluaciones realizadas, promedio general y actividad reciente desde un panel centralizado.",
                            color: "from-emerald-500 to-green-600",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/>`
                        },
                        {
                            title: "Registro de deportistas",
                            description: "Crea perfiles completos con datos personales, información profesional, historial de clubes, representante y títulos. Filtra por posición, nacionalidad y edad.",
                            color: "from-green-500 to-teal-600",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/>`
                        },
                        {
                            title: "Evaluaciones técnicas",
                            description: "Evalúa control de balón, pase corto, pase largo, regate, tiro y calidad técnica. Gráficos de radar para visualizar el nivel del jugador de forma intuitiva.",
                            color: "from-teal-500 to-emerald-400",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z"/>`
                        },
                        {
                            title: "Evaluaciones tácticas",
                            description: "Mide el posicionamiento, liderazgo, marcaje, presión, pérdida y lectura del juego. Complementa la evaluación técnica con el análisis táctico del jugador.",
                            color: "from-emerald-600 to-green-500",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 6.75V15m6-6v8.25m.503 3.498 4.875-2.437c.381-.19.622-.58.622-1.006V4.82c0-.836-.88-1.38-1.628-1.006l-3.869 1.934c-.317.159-.69.159-1.006 0L9.503 3.252a1.125 1.125 0 00-1.006 0L3.622 5.689C3.24 5.88 3 6.27 3 6.695V19.18c0 .836.88 1.38 1.628 1.006l3.869-1.934c.317-.159.69-.159 1.006 0l4.994 2.497c.317.158.69.158 1.006 0Z"/>`
                        },
                        {
                            title: "Campo táctico interactivo",
                            description: "Visualiza la alineación de los equipos sobre un campo de fútbol interactivo. Asigna jugadores a posiciones en formaciones tácticas Local vs Visitante.",
                            color: "from-green-600 to-teal-500",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 0v18M3 12h18M5.636 5.636l12.728 12.728M18.364 5.636 5.636 18.364"/>`
                        },
                        {
                            title: "Reportes con IA",
                            description: "Selecciona deportistas y configura qué incluir en el reporte: gráficos, datos personales, historial de clubes, premios y reconocimientos. Generación automática con IA.",
                            color: "from-teal-600 to-emerald-500",
                            icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456Z"/>`
                        }
                    ].map(feature => (
                        <div class="p-6 rounded-3xl bg-box-bg border border-box-border shadow-[0px_4px_24px_rgb(var(--box-sd))] flex flex-col gap-4 group hover:border-emerald-500/40 transition-colors">
                            <div class={`w-12 h-12 rounded-2xl bg-gradient-to-br ${feature.color} flex items-center justify-center shrink-0 shadow-lg`}>
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="white" class="w-6 h-6" set:html={feature.icon}></svg>
                            </div>
                            <div>
                                <h3 class="font-semibold text-heading-1 text-lg mb-2">{feature.title}</h3>
                                <p class="text-heading-3 text-sm leading-relaxed">{feature.description}</p>
                            </div>
                        </div>
                    ))}
                </div>
            </Container>
        </section>

        <!-- Screenshots -->
        <section id="screenshots" class="relative">
            <span class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-emerald-600 to-green-500 rounded-full blur-3xl opacity-10"></span>
            <span class="absolute bottom-0 left-0 w-64 h-64 bg-gradient-to-tr from-teal-500 to-emerald-400 rounded-full blur-3xl opacity-10"></span>
            <Container>
                <div class="text-center mb-12">
                    <span class="px-4 py-1.5 rounded-full border border-box-border bg-box-bg text-heading-3 text-sm font-medium">
                        Capturas de pantalla
                    </span>
                    <Title className="mt-4">
                        Una interfaz <span class="text-transparent bg-clip-text bg-gradient-to-br from-emerald-400 from-20% via-green-500 via-30% to-teal-600">oscura y precisa</span>
                    </Title>
                    <Paragraph className="mt-4 max-w-2xl mx-auto">
                        Diseñada para el trabajo del scout. Toda la información visible, clara y al alcance en cada pantalla.
                    </Paragraph>
                </div>

                <!-- Dashboard - imagen principal -->
                <div class="relative rounded-3xl overflow-hidden border border-box-border shadow-[0px_8px_40px_rgb(var(--box-sd))] mb-6">
                    <div class="absolute inset-0 bg-gradient-to-t from-body/60 to-transparent z-10 flex items-end p-8">
                        <div>
                            <span class="px-3 py-1 rounded-full bg-gradient-to-r from-emerald-500 to-green-600 text-white text-xs font-semibold">Dashboard</span>
                            <p class="mt-2 text-heading-1 font-semibold text-lg">Panel de control principal</p>
                            <p class="text-heading-3 text-sm">Métricas clave, distribución por posición, tendencia de evaluaciones y actividad reciente.</p>
                        </div>
                    </div>
                    <img
                        src="/images/elascout/dashboard.png"
                        alt="ElaScout - Dashboard principal"
                        width="1280"
                        height="720"
                        class="w-full object-cover max-h-[500px]"
                    />
                </div>

                <!-- Deportistas + Detalle -->
                <div class="grid sm:grid-cols-2 gap-6 mb-6">
                    <div class="relative rounded-3xl overflow-hidden border border-box-border shadow-[0px_4px_24px_rgb(var(--box-sd))] group">
                        <div class="absolute inset-0 bg-gradient-to-t from-body/70 to-transparent z-10 flex items-end p-6">
                            <div>
                                <span class="px-3 py-1 rounded-full bg-gradient-to-r from-green-500 to-teal-600 text-white text-xs font-semibold">Deportistas</span>
                                <p class="mt-2 text-heading-1 font-semibold">Gestión de jugadores</p>
                                <p class="text-heading-3 text-sm">Busca, filtra y administra todos los deportistas registrados.</p>
                            </div>
                        </div>
                        <img
                            src="/images/elascout/deportistas.png"
                            alt="ElaScout - Lista de deportistas"
                            width="640"
                            height="480"
                            class="w-full object-cover max-h-72 group-hover:scale-105 transition-transform duration-500"
                        />
                    </div>

                    <div class="relative rounded-3xl overflow-hidden border border-box-border shadow-[0px_4px_24px_rgb(var(--box-sd))] group">
                        <div class="absolute inset-0 bg-gradient-to-t from-body/70 to-transparent z-10 flex items-end p-6">
                            <div>
                                <span class="px-3 py-1 rounded-full bg-gradient-to-r from-teal-500 to-emerald-400 text-white text-xs font-semibold">Perfil</span>
                                <p class="mt-2 text-heading-1 font-semibold">Detalle del deportista</p>
                                <p class="text-heading-3 text-sm">Datos personales, historial de clubes, representante y títulos.</p>
                            </div>
                        </div>
                        <img
                            src="/images/elascout/detalle-info.png"
                            alt="ElaScout - Detalle del deportista"
                            width="640"
                            height="480"
                            class="w-full object-cover max-h-72 group-hover:scale-105 transition-transform duration-500"
                        />
                    </div>
                </div>

                <!-- Evaluaciones radar - imagen destacada -->
                <div class="relative rounded-3xl overflow-hidden border border-box-border shadow-[0px_8px_40px_rgb(var(--box-sd))] mb-6">
                    <div class="absolute inset-0 bg-gradient-to-t from-body/60 to-transparent z-10 flex items-end p-8">
                        <div>
                            <span class="px-3 py-1 rounded-full bg-gradient-to-r from-teal-600 to-emerald-500 text-white text-xs font-semibold">Evaluaciones</span>
                            <p class="mt-2 text-heading-1 font-semibold text-lg">Análisis técnico, táctico y físico</p>
                            <p class="text-heading-3 text-sm">Gráficos de radar con puntuaciones detalladas por cada habilidad del jugador.</p>
                        </div>
                    </div>
                    <img
                        src="/images/elascout/evaluaciones-radar.png"
